{
  "name": "@webservices/playwright-tests",
  "version": "1.0.0",
  "description": "End-to-end Playwright tests for webservices Web UIs with SSO",
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest --coverage",
    "test:unit:one": "jest --runTestsByPath",
    "test:unit:name": "jest --testNamePattern",
    "test:e2e": "npm run test:e2e:boundary && npm run test:e2e:app-smoke && npm run test:e2e:sso",
    "test:e2e:route": "PW_SKIP_GLOBAL_SETUP=1 PW_WORKERS=${PW_WORKERS:-1} playwright test tests/fast/route-contract.spec.ts",
    "test:e2e:boundary": "PW_SKIP_GLOBAL_SETUP=1 PW_WORKERS=${PW_WORKERS:-1} ./scripts/with-runtime-env.sh playwright test tests/fast/route-contract.spec.ts tests/fast/workspaces-boundary.spec.ts",
    "test:e2e:app-smoke": "PW_SKIP_GLOBAL_SETUP=1 PW_WORKERS=1 ./scripts/with-runtime-env.sh playwright test tests/fast/app-smoke.spec.ts",
    "test:e2e:sso": "PW_WORKERS=1 ./scripts/with-runtime-env.sh playwright test tests/fast/sso-session.spec.ts",
    "test:e2e:smoke": "npm run test:e2e:app-smoke",
    "test:e2e:deep": "PW_WORKERS=1 ./scripts/with-runtime-env.sh playwright test tests/deep",
    "test:e2e:deep:forward-auth": "PW_WORKERS=1 ./scripts/with-runtime-env.sh playwright test tests/deep/forward-auth",
    "test:e2e:deep:oidc": "PW_WORKERS=1 ./scripts/with-runtime-env.sh playwright test tests/deep/oidc",
    "test:e2e:visual": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-visual-suite.sh",
    "test:e2e:progression-visual": "PW_SKIP_GLOBAL_SETUP=1 PW_WORKERS=1 playwright test tests/visual/progression-dashboard.spec.ts",
    "test:e2e:workflow": "npm run test:e2e:deep",
    "test:e2e:all": "npm run test:e2e && npm run test:e2e:workflow && npm run test:e2e:visual",
    "test:e2e:one": "./scripts/with-runtime-env.sh playwright test",
    "test:ui": "./scripts/with-runtime-env.sh playwright test --ui",
    "test:debug": "./scripts/with-runtime-env.sh playwright test --debug",
    "test:headed": "./scripts/with-runtime-env.sh playwright test --headed",
    "test:report": "playwright show-report",
    "test:codegen": "playwright codegen",
    "screenshot-report": "ts-node generate-screenshot-report.ts",
    "build": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "devDependencies": {
    "@livekit/rtc-node": "^0.13.27",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "livekit-server-sdk": "^2.15.2",
    "pg": "^8.20.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
