{
  "name": "@webservices/playwright-tests",
  "version": "1.0.0",
  "description": "End-to-end Playwright tests for webservices Web UIs with SSO",
  "scripts": {
    "test": "sh -lc 'status=0; npm run test:unit || status=$?; npm run test:e2e || status=$?; exit $status'",
    "test:unit": "jest --coverage",
    "test:unit:one": "jest --runTestsByPath",
    "test:unit:name": "jest --testNamePattern",
    "test:e2e": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh boundary app-smoke sso",
    "test:e2e:route": "PW_WORKERS=${PW_WORKERS:-1} ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh route",
    "test:e2e:boundary": "PW_WORKERS=${PW_WORKERS:-1} ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh boundary",
    "test:e2e:app-smoke": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh app-smoke",
    "test:e2e:sso": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh sso",
    "test:e2e:mobile-smoke": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh mobile:smoke",
    "test:e2e:mobile-auth": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh mobile:auth",
    "test:e2e:mobile": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh mobile",
    "test:e2e:smoke": "npm run test:e2e:app-smoke",
    "test:e2e:deep": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh deep",
    "test:e2e:deep:forward-auth": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh deep:forward-auth",
    "test:e2e:deep:oidc": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh deep:oidc",
    "test:e2e:visual": "sh -lc 'PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh visual && ./scripts/with-runtime-env.sh node node_modules/ts-node/dist/bin.js scripts/validate-visual-review.ts'",
    "test:e2e:visual:review": "./scripts/with-runtime-env.sh node node_modules/ts-node/dist/bin.js scripts/validate-visual-review.ts --require-approved",
    "test:e2e:workflow": "npm run test:e2e:deep",
    "test:e2e:all": "PW_WORKERS=1 ./scripts/with-runtime-env.sh ./scripts/run-playwright-suite.sh all",
    "test:e2e:one": "./scripts/with-runtime-env.sh playwright test",
    "test:ui": "./scripts/with-runtime-env.sh playwright test --ui",
    "test:debug": "./scripts/with-runtime-env.sh playwright test --debug",
    "test:headed": "./scripts/with-runtime-env.sh playwright test --headed",
    "test:report": "playwright show-report",
    "test:codegen": "playwright codegen",
    "screenshot-report": "ts-node generate-screenshot-report.ts",
    "build": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "devDependencies": {
    "@livekit/rtc-node": "^0.13.27",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "livekit-server-sdk": "^2.15.2",
    "pg": "^8.20.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
