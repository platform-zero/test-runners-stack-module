{
  "schemaVersion": 1,
  "defaultViewport": {
    "width": 1440,
    "height": 1000
  },
  "captureMode": "stack-standard-evidence",
  "services": [
    {
      "slug": "jupyterhub",
      "name": "JupyterHub",
      "host": "jupyterhub",
      "features": [
        {
          "id": "lab-workspace",
          "title": "Notebook Workspace",
          "path": "/user-redirect/lab",
          "actions": [
            {
              "type": "waitForText",
              "text": "Launcher",
              "timeout": 20000
            },
            {
              "type": "clickText",
              "text": "No",
              "optional": true
            },
            {
              "type": "wait",
              "ms": 1200
            }
          ],
          "expectedText": [
            "Launcher",
            "Notebook",
            "Python"
          ],
          "operatorValue": "Shows an authenticated data-science and notebook workspace."
        },
        {
          "id": "file-browser",
          "title": "File Browser",
          "path": "/user-redirect/lab",
          "expectedText": [
            "Name",
            "Last Modified",
            "Launcher"
          ],
          "operatorValue": "Shows users can manage notebook files and project artifacts."
        },
        {
          "id": "launcher",
          "title": "Launcher and Runtimes",
          "path": "/user-redirect/lab",
          "expectedText": [
            "Launcher",
            "Notebook",
            "Console"
          ],
          "operatorValue": "Shows available notebook/runtime entry points."
        },
        {
          "id": "hub-home",
          "title": "Hub Home",
          "path": "/hub/home",
          "expectedText": [
            "Server",
            "Jupyter"
          ],
          "operatorValue": "Shows the shared service entry point and user server status."
        },
        {
          "id": "control-panel",
          "title": "User Server Controls",
          "path": "/hub/home",
          "expectedText": [
            "Stop My Server",
            "Token",
            "Server"
          ],
          "operatorValue": "Shows the service can expose operational controls to the user."
        }
      ]
    },
